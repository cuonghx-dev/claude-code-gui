<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for spawning the `claude` PTY child when it lives outside hardened-runtime-blessed paths. -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Permit dyld environment variable injection for portable-pty's PTY allocation on macOS. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>

  <!-- We disable library validation only when needed for unsigned `claude` paths.
       Currently false; flip to true if Phase 4 dogfood reveals notarization rejections. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <false/>
</dict>
</plist>
